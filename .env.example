# ==========================================================================
# Stock Market Bot - Environment Variables
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
# ==========================================================================

# ---------- Trading mode ----------
# Set to "true" ONLY when you want to place REAL orders with REAL money.
# Default is paper trading. Read all warnings before flipping this.
LIVE_TRADING=false

# Which broker adapter to use: paper | zerodha | dhan
BROKER=paper

# ---------- Zerodha Kite Connect ----------
# https://kite.trade/
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=
KITE_USER_ID=
# Used by `python -m cli login` to do daily TOTP-based access token refresh.
KITE_PASSWORD=
KITE_TOTP_SECRET=    # The TOTP base-32 seed shown when you set up 2FA

# ---------- Dhan ----------
# https://dhan.co/
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# ---------- Redis (used for state, caching ticks, positions) ----------
REDIS_URL=redis://localhost:6379/0

# ---------- Research agent (LLM) ----------
# Optional. If absent, research falls back to a heuristic-only mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# News feed for the research agent (RSS)
NEWS_FEEDS=https://www.moneycontrol.com/rss/MCtopnews.xml,https://www.livemint.com/rss/markets

# ---------- Notifications (email) ----------
# Leave SMTP_HOST blank to disable email alerts.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFY_TO=                # Comma-separated recipient emails
NOTIFY_LEVEL=INFO         # INFO logs every fill; WARNING only logs rejections/errors

# ---------- Misc ----------
LOG_LEVEL=INFO
TZ=Asia/Kolkata
